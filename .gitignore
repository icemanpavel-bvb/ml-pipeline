cat > .gitignore << 'EOF'
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Data files
train/*.csv
test/*.csv
*.pkl
*.json

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Pipeline outputs
quality_report.json
fix_history.json
scaler.pkl
model.pkl
EOF
